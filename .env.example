# Rust Legions — frontend environment template.
#
# Copy this file to `.env.local` (which is git-ignored) and fill in real values
# when you want the local Vite frontend to talk to a HOSTED Base44 backend:
#
#     cp .env.example .env.local
#
# You do NOT need this file when running `base44 dev` — the Base44 CLI injects
# the local backend values for you. It is only for the frontend-only workflow
# (`npm run dev` against a deployed backend).

# Identifies the Base44 app.
VITE_BASE44_APP_ID=your_app_id

# Where the Base44 Vite plugin proxies local /api requests.
# Point this at your deployed Base44 app URL.
VITE_BASE44_APP_BASE_URL=https://your-app.base44.app

# Optional: pin a specific deployed functions version. Leave unset/blank to use
# the latest deployed version (read by src/lib/app-params.js).
# VITE_BASE44_FUNCTIONS_VERSION=
